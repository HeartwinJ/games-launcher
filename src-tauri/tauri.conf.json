{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GamesLauncher",
  "version": "0.2.0",
  "identifier": "com.heartwin.gameslauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Games Launcher",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Heartwin Haveluck",
    "copyright": "Copyright © 2026 Heartwin Haveluck",
    "category": "Game",
    "shortDescription": "Minimal fancy launcher for installed Steam & Epic games",
    "longDescription": "A controller-friendly Windows launcher that unifies your installed Steam and Epic libraries into one TV-style grid.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/HeartwinJ/games-launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2QjUwQTgyNURFMjExNUUKUldSZUVlSmRnZ3ExdHB0OGpiSG1DR1NXc1poRUJpKzkydk1xR015dExoTXhwbE8xamtsT255KzYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
